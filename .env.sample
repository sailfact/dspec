# Copy to .env and fill in. Never commit the real .env.

# Bearer token required on every request to the MCP endpoint.
# Generate one with:  openssl rand -hex 32
# Leave blank to run unauthenticated (only safe on a trusted LAN).
MCP_AUTH_TOKEN=

# Path the MCP endpoint is served on (default /mcp).
MCP_PATH=/mcp

# Bind address / port inside the container (defaults are fine for Docker).
MCP_HOST=0.0.0.0
MCP_PORT=8000

# Cloudflare Tunnel token (only needed if you use the cloudflared service).
# Zero Trust > Networks > Tunnels > your tunnel > install connector.
TUNNEL_TOKEN=
