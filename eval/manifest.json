{
  "description": "Self-contained calibration eval for the dspec gate. Each task file under tasks/ embeds its full prompt and any input material, so a run is reproducible with no external context. Run each task through /spec, record the outcome, then /spec-stats.",
  "threshold_default": 60,
  "success_criteria": {
    "mechanical_tasks_gate_high_and_accepted_or_patched": "tasks 01-07",
    "novel_and_judgment_tasks_gate_low_or_rejected": "tasks 08-09, 16",
    "trap_tasks_gate_low_or_end_patched_rejected": "tasks 11-15; each run must yield bad-outcome data (a low gate score, or a verify-path patch/reject) so mean_confidence_bad is populated",
    "separation_points_min": 10,
    "separation_metric": "mean_confidence_good - mean_confidence_bad"
  },
  "tasks": [
    { "id": "01-gitignore-rust",       "file": "tasks/01-gitignore-rust.md",       "category": "mechanical", "expected_gate": "high",       "expected_outcome": ["accepted", "patched"] },
