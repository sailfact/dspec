    { "id": "05-systemd-unit",         "file": "tasks/05-systemd-unit.md",         "category": "mechanical", "expected_gate": "high",       "expected_outcome": ["accepted", "patched"] },
    { "id": "06-summarize-readme",     "file": "tasks/06-summarize-readme.md",     "category": "mechanical", "expected_gate": "high",       "expected_outcome": ["accepted", "patched"] },
    { "id": "07-bash-one-liner",       "file": "tasks/07-bash-one-liner.md",       "category": "mechanical", "expected_gate": "high",       "expected_outcome": ["accepted", "patched"] },
    { "id": "08-design-sync-cli",      "file": "tasks/08-design-sync-cli.md",      "category": "novel",      "expected_gate": "low",        "expected_outcome": ["discarded", "rejected"] },
    { "id": "09-sqlite-vs-jsonl",      "file": "tasks/09-sqlite-vs-jsonl.md",      "category": "judgment",   "expected_gate": "low",        "expected_outcome": ["discarded", "patched", "rejected"] },
